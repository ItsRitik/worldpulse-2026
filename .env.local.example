# WorldPulse 2026 — Environment variables
# Copy to .env.local and fill in your keys.
# All football data comes from API-Football (api-sports.io) only.

# Supabase — https://supabase.com (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # server-side only

# API-Football — https://dashboard.api-football.com/
APIFOOTBALL_KEY=your_api_football_key
NEXT_PUBLIC_APIFOOTBALL_KEY=your_api_football_key  # browser widget only

# Base URL the scoring cron uses to call its own API routes
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Scoring engine auth — strong random string in production
SCORING_SECRET=change-me

# Clerk auth — dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/fantasy/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/fantasy/login
